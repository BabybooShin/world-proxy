{
  "version": 2,
  "functions": {
    "api/proxy.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/proxy/:path*", "destination": "/api/proxy/:path*" },
    { "source": "/api/proxy",        "destination": "/api/proxy" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",              "value": "ALLOWALL" },
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS,HEAD" }
      ]
    }
  ]
}
